<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StockTracker.AddStockWindow"
        Title="添加股票"
        Width="250" Height="150"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True">
    
    <Border Background="#FF1E1E1E" CornerRadius="8" BorderBrush="#FF444444" BorderThickness="1">
        <StackPanel Margin="15" Spacing="10">
            <TextBlock Text="添加股票代码" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="输入6位数字 (如: 000001):" FontSize="10" Foreground="#FFAAAAAA"/>
            <TextBox Name="InputBox" Watermark="代码" Background="#FF2D2D2D" Foreground="White" BorderBrush="#FF555555"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Name="BtnCancel" Content="取消" Click="BtnCancel_Click" Background="#FF3E3E42" Foreground="White"/>
                <Button Name="BtnOk" Content="确定" Click="BtnOk_Click" Background="#FF007ACC" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
