## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
stocks.txt

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
# publish/

# NuGet Packages
*.nupkg
.nuget/
!packages/build/
packages/
*.nuget.props
*.nuget.targets

# Mac
.DS_Store

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Profiler
*.psess
*.vsp
*.vspx
*.sap

# Publish outputs
*.Publish.xml
*.pubxml
*.publishproj

# Code coverage
*.coveragegit reset --soft origin/master
*.coveragexml

# Setup Project
*.vdproj

# Ignore Windows Forms resx backup files
*.resx.bak
.idea
.claude